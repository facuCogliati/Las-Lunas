---
---
<section id="contacto" class="section contacto">
  <div class="container">
    <div class="contacto__grid">
      <!-- Left: info -->
      <div class="contacto__info">
        <p class="section-tag reveal">Hablemos</p>
        <h2 class="reveal" style="transition-delay:0.1s">
          Ponete en <span class="text-green">contacto</span>
        </h2>
        <p class="reveal" style="transition-delay:0.15s; color:var(--gray-mid)">
          Dejanos tu información y te responderemos lo antes posible.
        </p>

        <div class="contact-methods reveal-group" style="margin-top:2rem">
          <!-- WhatsApp -->
          <a
            href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20recibir%20m%C3%A1s%20informaci%C3%B3n%20de%20hospedaje%20para%20mi%20mascota%20en%20Las%20Lunas.%20"
            target="_blank"
            rel="noopener"
            class="contact-method"
          >
            <div class="contact-method__icon contact-method__icon--wa">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div class="contact-method__body">
              <strong>¡Escribinos por WhatsApp!</strong>
              <span>+54 9 11 5096-8576</span>
            </div>
            <svg class="contact-method__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <!-- Mail -->
          <a href="mailto:info@las-lunas.com.ar" class="contact-method">
            <div class="contact-method__icon contact-method__icon--mail">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div class="contact-method__body">
              <strong>¡Escribinos por mail!</strong>
              <span>info@las-lunas.com.ar</span>
            </div>
            <svg class="contact-method__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/hospedaje.laslunas/" target="_blank" rel="noopener" class="contact-method">
            <div class="contact-method__icon contact-method__icon--ig">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </div>
            <div class="contact-method__body">
              <strong>¡Seguinos en Instagram!</strong>
              <span>@hospedaje.laslunas</span>
            </div>
            <svg class="contact-method__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: quick form -->
      <div class="contacto__form reveal" style="transition-delay:0.2s">
        <div class="form-card">
          <h3>Dejanos tus datos</h3>
          <p style="color:var(--gray-mid); font-size:0.92rem; margin-bottom:1.5rem">Te responderemos a la brevedad por el canal que prefieras.</p>
          <div class="form-group">
            <label for="nombre">Tu nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="María García" />
          </div>
          <div class="form-group">
            <label for="mascota">Mascota y especie</label>
            <input type="text" id="mascota" name="mascota" placeholder="Ej: Toto, perro" />
          </div>
          <div class="form-group">
            <label for="servicio">Servicio de interés</label>
            <select id="servicio" name="servicio">
              <option value="">Seleccioná...</option>
              <option>Hospedaje para perros</option>
              <option>Hospedaje para gatos</option>
              <option>Traslados a domicilio</option>
              <option>Programa de adiestramiento</option>
              <option>Traslado internacional</option>
            </select>
          </div>
          <div class="form-group">
            <label for="mensaje">Mensaje (opcional)</label>
            <textarea id="mensaje" name="mensaje" rows="3" placeholder="Contanos las fechas, algún detalle especial..."></textarea>
          </div>
          <button type="button" class="btn btn-wa form-submit" id="form-submit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar por WhatsApp
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.contacto { background: var(--gray-light); }

.contacto__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}
@media (min-width: 900px) {
  .contacto__grid { grid-template-columns: 1fr 1fr; gap: 5rem; }
}

/* Methods */
.contact-methods { display: flex; flex-direction: column; gap: 0.75rem; }

.contact-method {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: var(--white);
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  transition: transform 0.2s, box-shadow 0.2s;
  color: var(--black);
}
.contact-method:hover {
  transform: translateX(4px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.08);
}

.contact-method__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.contact-method__icon--wa { background: #25D366; }
.contact-method__icon--mail { background: var(--green); }
.contact-method__icon--ig { background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }

.contact-method__body { flex: 1; }
.contact-method__body strong { display: block; font-size: 0.95rem; color: var(--black); margin-bottom: 2px; }
.contact-method__body span { font-size: 0.85rem; color: var(--gray-mid); }

.contact-method__arrow { color: var(--gray-mid); flex-shrink: 0; }

/* Form */
.form-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  border: 1px solid rgba(0,0,0,0.07);
  box-shadow: 0 4px 30px rgba(0,0,0,0.05);
}
.form-card h3 { margin-bottom: 0.25rem; font-size: 1.35rem; color: var(--green-dark); }

.form-group { margin-bottom: 1.25rem; }
.form-group label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--gray-dark);
  margin-bottom: 6px;
  letter-spacing: 0.02em;
}
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1.5px solid rgba(0,0,0,0.12);
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--black);
  background: var(--white);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(45,106,79,0.1);
}
.form-group textarea { resize: vertical; min-height: 90px; }

.form-submit { width: 100%; justify-content: center; font-size: 1rem; padding: 0.9rem; }
</style>

<script>
document.getElementById('form-submit')?.addEventListener('click', () => {
  const nombre = (document.getElementById('nombre') as HTMLInputElement)?.value || '';
  const mascota = (document.getElementById('mascota') as HTMLInputElement)?.value || '';
  const servicio = (document.getElementById('servicio') as HTMLSelectElement)?.value || '';
  const mensaje = (document.getElementById('mensaje') as HTMLTextAreaElement)?.value || '';

  let text = `Hola! Quiero recibir más información de hospedaje para mi mascota en Las Lunas.`;
  if (nombre) text += `\n\nMi nombre es ${nombre}.`;
  if (mascota) text += `\nMi mascota es ${mascota}.`;
  if (servicio) text += `\nEstoy interesado/a en: ${servicio}.`;
  if (mensaje) text += `\n\n${mensaje}`;

  window.open(`https://api.whatsapp.com/send?phone=5491150968576&text=${encodeURIComponent(text)}`, '_blank');
});
</script>
