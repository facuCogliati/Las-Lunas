          <div class="contact-method__body">
            <strong>¡Unite a la familia Las Lunas!</strong>
            <span>Tips, conducta y salud. @hospedaje.laslunas</span>
          </div>
          <svg
            class="contact-method__arrow"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
