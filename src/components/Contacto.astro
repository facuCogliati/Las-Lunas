    </div>
  </div>
</section>

<style>
  .contacto {
    background: var(--white);
    padding: 6rem 0 8rem 0;
  }

  /* --- HEADER REDISEÑADO --- */
  .contacto__header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    background: var(--green-pale);
    border: 1px solid rgba(45, 106, 79, 0.1);
    border-radius: 50px;
    color: var(--green-dark);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }

  .contacto__header h2 {
    font-size: 3rem;
    color: var(--green-dark);
    margin-bottom: 1rem;
    font-family: var(--font-display);
  }

  .text-accent {
    color: var(--accent);
  }

  .section-lead {
    color: var(--gray-mid);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- CONTENIDO --- */
  .contacto__content {
    max-width: 700px; /* Ancho máximo para mantenerlo centrado y prolijo */
    margin: 0 auto;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    color: var(--black);
  }

  .contact-method:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  /* Colores sutiles para cada tarjeta */
  .method-wa {
    background: #f0fdf4; /* Verde agua muy claro */
    border: 1px solid #bbf7d0;
  }
  .method-wa:hover {
    border-color: #25d366;
  }

  .method-mail {
    background: var(--green-pale); /* Tu verde pálido */
    border: 1px solid rgba(45, 106, 79, 0.1);
  }
  .method-mail:hover {
    border-color: var(--green);
  }

  .method-ig {
    background: #fff1f2; /* Rosado/Naranja muy claro */
    border: 1px solid #fecdd3;
  }
  .method-ig:hover {
    border-color: #e6683c;
  }

  /* Iconos */
  .contact-method__icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contact-method__icon--wa {
    background: #25d366;
  }
  .contact-method__icon--mail {
    background: var(--green);
  }
  .contact-method__icon--ig {
    background: linear-gradient(
      135deg,
      #f09433 0%,
      #e6683c 25%,
      #dc2743 50%,
      #cc2366 75%,
      #bc1888 100%
    );
  }

  /* Textos */
  .contact-method__body {
    flex: 1;
  }
  .contact-method__body strong {
    display: block;
    font-size: 1.1rem;
    color: var(--green-dark);
    margin-bottom: 4px;
  }
  .contact-method__body span {
    font-size: 0.95rem;
    color: var(--gray-mid);
  }

  .contact-method__arrow {
    color: var(--gray-mid);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .contact-method:hover .contact-method__arrow {
    transform: translateX(4px);
    color: var(--green-dark);
  }

  @media (max-width: 600px) {
    .contact-method {
      padding: 1.25rem;
      gap: 1rem;
    }
    .contact-method__icon {
      width: 48px;
      height: 48px;
    }
  }
</style>
