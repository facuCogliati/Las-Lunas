          ></path>
        </svg>
        <span>@hospedaje.laslunas</span>
      </a>
      <a
        href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20recibir%20m%C3%A1s%20informaci%C3%B3n%20de%20hospedaje%20para%20mi%20mascota%20en%20Las%20Lunas.%20"
        target="_blank"
        rel="noopener"
        aria-label="WhatsApp"
        class="pre-header__link"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        <span>+54 9 11 5096-8576</span>
      </a>
      <a href="mailto:info@las-lunas.com.ar" class="pre-header__link">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <span>info@las-lunas.com.ar</span>
      </a>
    </div>
  </div>

  <nav class="nav">
    <div class="nav__inner container">
      <a href="#inicio" class="nav__logo">
        <Image src={logoLasLunas} alt="Las Lunas Logo" class="nav__logo-img" />
      </a>

      <button
        class="nav__burger"
        id="burger"
        aria-label="Menú"
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>

      <ul class="nav__links" id="nav-links">
        <li><a href="#conocenos" class="nav__link">Conocenos</a></li>
        <li><a href="#instalaciones" class="nav__link">Instalaciones</a></li>
        <li><a href="#servicios" class="nav__link">Servicios</a></li>
        <li><a href="#testimonios" class="nav__link">Testimonios</a></li>
        <li><a href="#contacto" class="nav__link">Contacto</a></li>
        <li class="nav__cta">
          <a
            href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20reservar%20hospedaje%20para%20mi%20mascota%20en%20Las%20Lunas."
            target="_blank"
            class="btn btn-primary nav__reserve"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Reservar
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  /* Variables locales para el header (Ajusta estos valores si quieres cambiar la altura general) */
  :root {
    --pre-header-h: 36px;
    --header-h-desktop: 80px; /* Altura principal en PC */
    --header-h-mobile: 70px; /* Altura principal en Celulares */
  }

  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: box-shadow 0.3s ease;
  }

  /* Pre-header */
  .pre-header {
    background: var(--green-dark);
    height: var(--pre-header-h);
    overflow: hidden;
    transition:
      height 0.3s ease,
      opacity 0.3s ease;
  }
  .pre-header__inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: flex-end;
  }
  .pre-header__link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.88rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  .pre-header__link:hover {
    color: var(--green-pale);
  }
  .pre-header__link span {
    display: none;
  }
  @media (min-width: 640px) {
    .pre-header__link span {
      display: inline;
    }
  }

  /* Main nav */
  .nav {
    background: var(--white);
    height: var(--header-h-mobile); /* Altura base para mobile */
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    transition:
      height 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }
  @media (min-width: 900px) {
    .nav {
      height: var(--header-h-desktop);
    } /* Altura para desktop */
  }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between; /* Asegura que el logo y el menú estén separados */
    gap: 1rem;
  }

  /* ─── LOGO (Control de tamaño) ─── */
  .nav__logo {
    display: flex;
    align-items: center;
    height: 100%; /* El contenedor ocupa todo el alto disponible del header */
    padding: 10px 0; /* Pequeño margen arriba y abajo para que el logo no toque los bordes */
    text-decoration: none;
  }

  .nav__logo-img {
    height: 100%; /* La imagen se adapta al alto del padding anterior */
    width: auto; /* Mantiene la proporción original */
    max-height: 60px; /* Un límite máximo por seguridad */
    object-fit: contain; /* Asegura que el logo no se deforme */
  }

  /* Links */
  .nav__links {
    display: none;
    list-style: none;
    align-items: center;
    gap: 0.25rem;
  }
  @media (min-width: 900px) {
    .nav__links {
      display: flex;
    }
  }

  .nav__link {
    padding: 0.5rem 0.85rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--gray-dark);
    border-radius: var(--radius);
    text-decoration: none;
    transition:
      color 0.2s,
      background 0.2s;
  }
  .nav__link:hover {
    color: var(--green);
    background: var(--green-pale);
  }

  /* Reserve button */
  .nav__cta {
    margin-left: 0.5rem;
  }
  .nav__reserve {
    font-size: 0.88rem;
    padding: 0.6rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }

  /* Burger */
  .nav__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  @media (min-width: 900px) {
    .nav__burger {
      display: none;
    }
  }
  .nav__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--gray-dark);
    border-radius: 2px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  /* ─── Compact mode (Cuando el usuario hace scroll) ─── */
  #site-header.compact .pre-header {
    height: 0; /* Oculta la barra superior verde */
    opacity: 0;
  }
  #site-header.compact .nav {
    /* Mantenemos una altura un poco más pequeña que la inicial, pero fija y controlada */
    height: 60px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.1);
  }

  /* El logo se achica un poco automáticamente al reducirse el height de .nav */
  #site-header.compact .nav__logo {
    padding: 8px 0;
  }

  /* ─── Mobile menu open ─── */
  @media (max-width: 899px) {
    .nav__links.open {
      display: flex;
      flex-direction: column;
      position: fixed;
      /* Top calcula la altura actual del header (pre-header + nav) */
      top: calc(var(--pre-header-h) + var(--header-h-mobile));
      left: 0;
      right: 0;
      background: var(--white);
      padding: 1.5rem;
      gap: 0.5rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
      border-top: 1px solid var(--green-pale);
    }

    /* Si el menú se abre mientras está compacto (con scroll) */
    #site-header.compact .nav__links.open {
      top: 60px; /* Coincide con la altura de .nav en modo compacto */
    }
  }
</style>

<script>
  const burger = document.getElementById("burger");
  const navLinks = document.getElementById("nav-links");
  const header = document.getElementById("site-header");

  // Lógica del menú hamburguesa
  burger?.addEventListener("click", () => {
    const open = navLinks?.classList.toggle("open");
    burger.setAttribute("aria-expanded", String(open));
  });

  // Cerrar menú al hacer clic en un enlace
  navLinks?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      navLinks.classList.remove("open");
      burger?.setAttribute("aria-expanded", "false");
    });
  });

  // Opcional: Lógica para el modo "compacto" al hacer scroll
  // (Si ya lo tienes en otro archivo global, puedes omitir esto)
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("compact");
    } else {
      header?.classList.remove("compact");
    }
  });
</script>
