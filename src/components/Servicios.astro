---
// Importar imágenes del programa de adiestramiento
import train1 from "../assets/servicios/ad 4.jpg";
import train2 from "../assets/servicios/ad 2.jpg";
import train3 from "../assets/servicios/ad 3.jpg";
import train4 from "../assets/servicios/ad 4.jpg";
import train5 from "../assets/servicios/ad 2.jpg";

import intTransport1 from "../assets/servicios/ad 2.jpg";
import intTransport2 from "../assets/servicios/ad 2.jpg";
import intTransport3 from "../assets/servicios/ad 2.jpg";
import intTransport4 from "../assets/servicios/ad 2.jpg";

// Importar imágenes de traslado internacional
// import intTransport1 from "../assets/servicios/internacional/1.jpg";
// import intTransport2 from "../assets/servicios/internacional/2.jpg";
// import intTransport3 from "../assets/servicios/internacional/3.jpg";
// import intTransport4 from "../assets/servicios/internacional/4.jpg";

// Importar logo de Latam Pet Transport
// import latamLogo from "../assets/servicios/latam-pet-logo.png";

// Importar imagen de veterinario
// import vetImage from "../assets/servicios/veterinario.jpg";

const trainingImages = [
  { src: train1.src, alt: "Adiestramiento profesional" },
  { src: train2.src, alt: "Entrenamiento canino" },
  { src: train3.src, alt: "Trabajo con adiestrador" },
  { src: train4.src, alt: "Comandos básicos" },
  { src: train5.src, alt: "Educación canina" },
];

const internationalImages = [
  { src: intTransport1.src, alt: "Traslado internacional de mascotas" },
  { src: intTransport2.src, alt: "Transporte seguro" },
  { src: intTransport3.src, alt: "Documentación internacional" },
  { src: intTransport4.src, alt: "Viaje con mascotas" },
];
---

<section id="servicios" class="section servicios">
  <div class="container">
    <div class="servicios__header reveal">
      <div class="header-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
          ></path>
        </svg>
        <span>LO QUE OFRECEMOS</span>
      </div>

      <div class="header-two-col">
        <div class="header-left">
          <h2>Nuestros <span class="text-accent">servicios</span></h2>
          <p class="header-body">
            Todo lo que necesita tu mascota en un entorno seguro, natural y
            profesional.
          </p>
        </div>
      </div>
    </div>

    <!-- BENTO GRID CARDS A, B, C -->
    <div class="services-bento-grid">
      <!-- Card A: Hospedaje Perros -->
      <article
        class="bento-service card-dark reveal"
        style="transition-delay: 0.1s;"
      >
        <div class="service-content">
          <div class="service-header-row">
            <div class="service-number card-a-number">01</div>
            <div class="stat-icon dark-icon">
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M12 5c2 0 4 2 4 4v2h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2h2V9c0-2 2-4 4-4z"
                ></path></svg
              >
            </div>
          </div>
          <h3 class="service-title" style="color: var(--accent);">
            Hospedaje para perros
          </h3>
          <p class="service-description">
            Perros en libertad en grupos homogéneos, siempre supervisados.
            Descanso cómodo y seguro por la noche.
          </p>
          <a href="#contacto" class="service-cta card-a-btn">
            <span>Consultar</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
              ><path
                d="M4 10H16M16 10L10 4M16 10L10 16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path></svg
            >
          </a>
        </div>
      </article>

      <!-- Card B: Hospedaje Gatos -->
      <article
        class="bento-service card-accent reveal"
        style="transition-delay: 0.2s;"
      >
        <div class="service-content">
          <div class="service-header-row">
            <div class="service-number card-b-number">02</div>
            <div class="stat-icon accent-icon">
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                ></path></svg
              >
            </div>
          </div>
          <h3 class="service-title" style="color: white;">
            Hospedaje para gatos
          </h3>
          <p class="service-description">
            Gateras amplias e individuales, ambientadas con troncos, plantas y
            casitas para que se sientan en casa.
          </p>
          <a href="#contacto" class="service-cta card-b-btn">
            <span>Consultar</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
              ><path
                d="M4 10H16M16 10L10 4M16 10L10 16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path></svg
            >
          </a>
        </div>
      </article>

      <!-- Card C: Traslados -->
      <article
        class="bento-service card-white reveal"
        style="transition-delay: 0.3s;"
      >
        <div class="service-content">
          <div class="service-header-row">
            <div class="service-number card-c-number">03</div>
            <div class="stat-icon outline-icon">
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><rect x="1" y="3" width="15" height="13"></rect><polygon
                  points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle
                  cx="5.5"
                  cy="18.5"
                  r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"
                ></circle></svg
              >
            </div>
          </div>
          <h3 class="service-title text-dark">Traslados a domicilio</h3>
          <p class="service-description">
            Retiro y devolución con camionetas acondicionadas y personal
            capacitado.
          </p>
          <div class="service-meta-mini">
            <span>Lun a Vie: 8:00 - 16:00 hs</span>
            <a
              href="https://docs.google.com/document/d/1nPaS-Ibv_P7T9CQX2_zNQY6iKw26Yw7o2Eo9KqxqQtQ/edit?usp=drive_link"
              target="_blank"
              class="meta-link">Requisitos sanitarios →</a
            >
          </div>
          <a href="#contacto" class="service-cta card-c-btn">
            <span>Consultar</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
              ><path
                d="M4 10H16M16 10L10 4M16 10L10 16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path></svg
            >
          </a>
        </div>
      </article>
    </div>

    <!-- CARD D: Programa de Adiestramiento -->
    <div
      class="training-full-width card-dark reveal"
      style="transition-delay: 0.4s;"
    >
      <div class="training-content-area">
        <span class="training-badge">Programa Intensivo</span>
        <h3 class="training-title">Programas de adiestramiento</h3>

        <div class="training-sections-grid">
          <div class="training-col">
            <div class="training-section">
              <h4 class="section-title-small">¿En qué consiste?</h4>
              <p class="section-text">
                Su perro estará hospedado con nosotros 30 días corridos, donde
                trabajará diariamente con el adiestrador.
              </p>
            </div>

            <div class="training-section">
              <h4 class="section-title-small">¿Qué incluye?</h4>
              <ul class="includes-list">
                <li>Hospedaje por 30 días.</li>
                <li>
                  Traslados incluidos: retiro y devolución a tu domicilio.
                </li>
                <li>Alimento premium durante toda la estadía.</li>
                <li>Baños sanitarios.</li>
                <li>Asistencia veterinaria permanente.</li>
                <li>Informe de avances e instructivo final.</li>
              </ul>
            </div>

            <div class="training-cta">
              <a
                href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20recibir%20m%C3%A1s%20informaci%C3%B3n..."
                class="btn-whatsapp"
                target="_blank"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                  ></path></svg
                >
                ¡Quiero más información!
              </a>
            </div>
          </div>

          <div class="training-col">
            <div class="training-section">
              <h4 class="section-title-small">
                ¿Qué logrará con este programa?
              </h4>
              <div class="table-responsive">
                <table class="commands-table">
                  <tbody>
                    <tr
                      ><td class="cmd-name">Junto</td><td
                        >Camina junto al guía.</td
                      ></tr
                    >
                    <tr
                      ><td class="cmd-name">Sit / Down</td><td
                        >Se sienta / Se echa.</td
                      ></tr
                    >
                    <tr
                      ><td class="cmd-name">Stá o parado</td><td>Se para.</td
                      ></tr
                    >
                    <tr
                      ><td class="cmd-name">Vení</td><td
                        >Acude al llamado siempre.</td
                      ></tr
                    >
                    <tr
                      ><td class="cmd-name">Varía pos.</td><td
                        >Se queda en las posiciones aprendidas.</td
                      ></tr
                    >
                    <tr
                      ><td class="cmd-name">Off</td><td
                        >Aprende a no saltar sobre la gente.</td
                      ></tr
                    >
                  </tbody>
                </table>
              </div>
            </div>

            <div class="training-section guarantee-box-wrapper">
              <div class="guarantee-box card-accent">
                <div class="guarantee-header">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                      d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"
                    ></path></svg
                  >
                  <h5 class="guarantee-title">Garantía de 3 meses</h5>
                </div>
                <div class="guarantee-content">
                  <p>
                    Garantizamos el correcto funcionamiento de los comandos. Si
                    alguno falla, lo reforzamos en nuestro predio.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="training-gallery-bottom">
        <div class="gallery-scroll-track">
          {
            trainingImages.map((img) => (
              <div class="gallery-img-card">
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            ))
          }
          {
            trainingImages.map((img) => (
              <div class="gallery-img-card" aria-hidden="true">
                <img src={img.src} alt="" loading="lazy" />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- CARD E: Traslado Internacional -->
    <div
      class="international-transport-card reveal"
      style="transition-delay: 0.5s;"
    >
      <div class="international-content">
        <div class="international-text-area">
          <a
            href="https://www.latampettransport.com/es/"
            target="_blank"
            class="latam-logo-link"
          >
            <!-- <img
              src={latamLogo.src}
              alt="Latam Pet Transport"
              class="latam-logo"
            /> -->
          </a>

          <h3 class="international-title">
            Traslado internacional de mascotas
          </h3>

          <p class="international-description">
            ¿Viajás con tu mascota? Te acompañamos paso a paso para organizar su
            traslado internacional de forma segura y profesional.
          </p>

          <a
            href="https://www.latampettransport.com/es/quote/"
            target="_blank"
            class="btn-international"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Solicitar cotización
          </a>
        </div>

        <div class="international-gallery">
          <div class="int-gallery-grid">
            {
              internationalImages.map((img, index) => (
                <div class={`int-img-card int-img-${index + 1}`}>
                  <img src={img.src} alt={img.alt} loading="lazy" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- CARD F: Servicios Generales -->
    <div class="general-services-card reveal" style="transition-delay: 0.6s;">
      <div class="general-services-grid">
        <div class="general-service-item">
          <div class="general-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
          <h4 class="general-service-title">Supervisión permanente</h4>
          <p class="general-service-desc">
            Monitoreo continuo 24/7 para garantizar el bienestar de tu mascota.
          </p>
        </div>

        <div class="general-service-item">
          <div class="general-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h4 class="general-service-title">Limpieza constante</h4>
          <p class="general-service-desc">
            Higiene y desinfección diaria de todas las instalaciones.
          </p>
        </div>

        <div class="general-service-item">
          <div class="general-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
            </svg>
          </div>
          <h4 class="general-service-title">Baños sanitarios</h4>
          <p class="general-service-desc">
            Servicio de higiene y cuidado estético profesional.
          </p>
        </div>

        <div class="general-service-item general-service-highlight">
          <div class="highlight-content">
            <div class="highlight-left">
              <div class="general-icon highlight-icon">
                <svg
                  width="36"
                  height="36"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                </svg>
              </div>
              <div>
                <h4
                  class="general-service-title"
                  style="margin-bottom: 0.25rem;"
                >
                  Asistencia veterinaria
                </h4>
                <p class="general-service-desc">
                  Atención profesional ante cualquier urgencia.
                </p>
              </div>
            </div>
            <div class="highlight-image">
              <!-- <img
                src={vetImage.src}
                alt="Veterinario profesional"
                loading="lazy"
              /> -->
            </div>
          </div>
        </div>

        <div class="general-service-item">
          <div class="general-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
              ></path>
            </svg>
          </div>
          <h4 class="general-service-title">Alimento premium</h4>
          <p class="general-service-desc">
            Nutrición balanceada de la más alta calidad.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════════════════════════════════
     SERVICIOS SECTION (Sincronizado con Conocenos)
     ══════════════════════════════════════════════════════════════════ */
  .servicios {
    background: var(--white);
    padding: 6rem 0;
    position: relative;
  }

  /* ── HEADER ── */
  .servicios__header {
    margin-bottom: 4rem;
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: var(--green-pale);
    border: 1px solid rgba(45, 106, 79, 0.1);
    border-radius: 50px;
    color: var(--green-dark);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }

  .header-two-col {
    display: flex;
    align-items: flex-start;
    gap: 7rem;
  }

  .header-left h2 {
    margin-bottom: 1rem;
  }

  .text-accent {
    color: var(--accent);
  }

  .header-body {
    color: var(--gray-mid);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 560px;
  }

  /* ══════════════════════════════════════════════════════════════════
     BENTO GRID DE SERVICIOS (Cards A, B, C)
     ══════════════════════════════════════════════════════════════════ */
  .services-bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .bento-service {
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    height: 100%;
  }

  .bento-service:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
  }

  .service-content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .service-number {
    font-size: 3.5rem;
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 1;
    opacity: 1 !important;
  }

  .text-dark {
    color: var(--green-dark);
  }

  /* --- DEFINICIÓN DE COLORES BASE DE CADA TARJETA --- */
  .card-dark {
    background: var(--green-dark);
    color: var(--white);
  }
  .card-dark .dark-icon {
    background: var(--accent);
    color: var(--white);
  }
  .card-dark .service-description {
    color: var(--green-pale);
  }

  .card-accent {
    background: var(--accent);
    color: var(--green-dark);
  }
  .card-accent .accent-icon {
    background: white;
    color: var(--green-dark);
  }
  .card-accent .service-description {
    color: var(--green-dark);
    opacity: 0.85;
  }

  .card-white {
    background: var(--white);
    color: var(--black);
    border: 2px solid var(--green-pale);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }
  .card-white .outline-icon {
    background: var(--green-dark);
    color: white;
  }
  .card-white .service-description {
    color: var(--gray-mid);
  }

  /* --- EL HILO VISUAL (Cruces de colores) --- */
  .card-a-number {
    color: var(--accent);
  }
  .card-a-btn {
    background: var(--accent);
    color: var(--green-dark);
  }
  .card-a-btn:hover {
    background: var(--white);
    color: var(--green-dark);
  }

  .card-b-number {
    color: var(--white);
  }
  .card-b-btn {
    background: var(--white);
    color: var(--green-dark);
  }
  .card-b-btn:hover {
    background: var(--green-dark);
    color: var(--white);
  }

  .card-c-number {
    color: var(--green-dark);
  }
  .card-c-btn {
    background: var(--green-dark);
    color: var(--white);
  }
  .card-c-btn:hover {
    background: var(--accent);
    color: var(--green-dark);
  }

  .stat-icon {
    font-size: 2rem;
    width: 60px;
    height: 60px;
    display: flex;
