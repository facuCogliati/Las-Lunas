            ></path></svg
          >
        </a>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <span class="copyright">© 2026 Las Lunas.</span>
      <a
        href="/requisitos"
        target="_blank"
        rel="noopener"
        class="requisitos-link"
      >
        Requisitos sanitarios para ingresar al predio
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1b4332; /* var(--green-dark) puro */
    color: var(--white, #ffffff);
    padding-top: 2rem; /* Agregué un poco de padding superior ya que no hay olas */
    position: relative;
  }

  /* --- CONTENIDO SIMPLE --- */
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0; /* Ajustado el padding para que no quede tan separado */
  }

  /* --- NUEVO: Estilos del Logo --- */
  .footer-logo-container {
    flex: 1; /* Para que empuje la navegación al centro */
  }

  .footer-logo {
    height: 45px;
    width: auto;
    filter: brightness(0) invert(1); /* Pone el logo en blanco puro sobre el fondo oscuro */
  }

  .footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex: 1; /* Para mantenerlo centrado */
  }

  .footer-link {
    color: var(--white, #ffffff);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--accent, #a3e635);
  }

  .footer-dot {
    color: rgba(255, 255, 255, 0.4);
  }

  /* Redes Sociales */
  .footer-socials {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    flex: 1; /* Para que quede alineado a la derecha */
  }

  .social-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: transform 0.2s ease;
  }

  .social-icon:hover {
    transform: translateY(-3px);
  }

  .wa-icon {
    background: #25d366;
  }
  .ig-icon {
    background: linear-gradient(
      135deg,
      #f09433 0%,
      #e6683c 25%,
      #dc2743 50%,
      #cc2366 75%,
      #bc1888 100%
    );
  }

  /* Divisor y Bottom */
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 1.5rem 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 2.5rem;
  }

  .copyright {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
  }

  /* Texto chiquito (Requisitos) */
  .requisitos-link {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7); /* Gris clarito sutil */
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .requisitos-link:hover {
    color: var(--white, #ffffff);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }

    /* Reseteamos los flex: 1 en móviles para que no rompan el centrado */
    .footer-logo-container,
    .footer-nav,
    .footer-socials {
      flex: unset;
      justify-content: center;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
