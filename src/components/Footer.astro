---
// Importamos el logo. Asegúrate de que la ruta coincida con la ubicación real de tu archivo.
// Si el logo está en public/, puedes usar src="/las lunas.png" directamente en el img.
import logoLasLunas from "../assets/las lunas.png";
---

<footer class="footer">
  <div class="container">
    <div class="footer__content">
      <div class="footer__left">
        <a
          href="#inicio"
          class="footer__logo-link"
          aria-label="Volver al inicio"
        >
          <img
            src={logoLasLunas.src}
            alt="Logo Las Lunas"
            class="footer__logo-img"
          />
        </a>

        <nav class="footer__nav">
          <a href="#inicio" class="footer__link">Inicio</a>
          <span class="divider">•</span>
          <a href="/galeria" class="footer__link">Galería de fotos</a>
        </nav>
      </div>

      <div class="footer__social">
        <a
          href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20recibir%20m%C3%A1s%20informaci%C3%B3n%20de%20hospedaje%20para%20mi%20mascota%20en%20Las%20Lunas.%20"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
          class="social-icon wa-icon"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/hospedaje.laslunas/"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="social-icon ig-icon"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
            ></path></svg
          >
        </a>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="copyright">© 2025 Las Lunas. Todos los derechos reservados.</p>

      <a
        href="https://docs.google.com/document/d/1nPaS-Ibv_P7T9CQX2_zNQY6iKw26Yw7o2Eo9KqxqQtQ/edit?usp=drive_link"
        target="_blank"
        rel="noopener"
        class="requisitos-link"
      >
        Requisitos sanitarios para ingresar al predio
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    /* Fondo oscuro para contrastar con la sección blanca de Contacto */
    background: #0d2118; /* Un verde un poco más profundo que var(--green-dark) */
    padding: 5rem 0 2rem;
    color: var(--white);
  }

  /* ── CONTENIDO PRINCIPAL ── */
  .footer__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer__content {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer__left {
      align-items: flex-start;
    }
  }

  /* Logo */
  .footer__logo-link {
    display: block;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .footer__logo-link:hover {
    transform: scale(1.05);
  }

  .footer__logo-img {
    height: 40px; /* Ajusta la altura según la proporción de tu imagen */
    width: auto;
    object-fit: contain;
    /* Si la imagen "las lunas.png" tiene texto oscuro, 
       quizás necesites aplicarle un filtro para que se vea en fondo oscuro:
       filter: brightness(0) invert(1); */
  }

  /* Navegación (Inicio / Galería) */
  .footer__nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer__link {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85); /* Blanco suavizado */
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--accent, #a3e635);
  }

  .divider {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8rem;
  }

  /* Redes Sociales */
  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .social-icon:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .wa-icon {
    background: #25d366;
  }
  .ig-icon {
    background: linear-gradient(
      135deg,
      #f09433 0%,
      #e6683c 25%,
      #dc2743 50%,
      #cc2366 75%,
      #bc1888 100%
    );
  }

  /* ── BOTTOM (Legales y Requisitos) ── */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  /* El texto chiquito (adaptado para fondo oscuro) */
  .requisitos-link {
    font-size: 0.8rem;
    color: rgba(
      255,
      255,
      255,
      0.6
    ); /* Gris claro para ser sutil pero legible */
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 400;
    transition: color 0.2s ease;
  }

  .requisitos-link:hover {
    color: var(--white);
  }
</style>
