    <div class="footer-content">
      <div class="footer-logo-container">
        <img src={logoLasLunas.src} alt="Logo Las Lunas" class="footer-logo" />
      </div>

      <nav class="footer-nav">
        <a href="#inicio" class="footer-link">Inicio</a>
        <span class="footer-dot">•</span>
        <a href="/galeria" class="footer-link">Galería de fotos</a>
      </nav>

      <div class="footer-socials">
        <a
          href="https://api.whatsapp.com/send?phone=5491150968576"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
          class="social-icon wa-icon"
        >
