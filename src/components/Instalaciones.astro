---
---
<section id="instalaciones" class="section instalaciones">
  <div class="container">
    <div class="instalaciones__header reveal">
      <p class="section-tag">Nuestro predio</p>
      <h2>Instalaciones <span class="text-green">de primer nivel</span></h2>
      <p class="instalaciones__intro">Más de 6.000 m² diseñados para el bienestar y la felicidad de tu mascota en Pilar, Buenos Aires.</p>
    </div>

    <!-- Photo mosaic -->
    <div class="mosaic reveal">
      <div class="mosaic__big">
        <img src="https://lh3.googleusercontent.com/d/1vSqgVBtCkioSBiVIXGaYtdQF9kusdRnn" alt="Predio Las Lunas" loading="lazy" onerror="this.src='https://picsum.photos/seed/inst1/800/600'" />
        <div class="mosaic__label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          Pilar, Buenos Aires
        </div>
      </div>
      <div class="mosaic__grid">
        <img src="https://picsum.photos/seed/inst2/400/300" alt="Área verde" loading="lazy" />
        <img src="https://picsum.photos/seed/inst3/400/300" alt="Pileta" loading="lazy" />
        <img src="https://picsum.photos/seed/inst4/400/300" alt="Zona techada" loading="lazy" />
        <img src="https://picsum.photos/seed/inst5/400/300" alt="Gatera" loading="lazy" />
      </div>
    </div>

    <!-- Feature cards -->
    <div class="features reveal-group">
      <div class="feature-card">
        <span class="feature-card__icon">🌿</span>
        <h3>6.000 m² de área verde</h3>
        <p>Espacio amplio para correr y jugar con supervisión permanente.</p>
      </div>
      <div class="feature-card">
        <span class="feature-card__icon">🌳</span>
        <h3>Arboleda y pileta</h3>
        <p>Ambientación natural para el disfrute y bienestar de cada mascota.</p>
      </div>
      <div class="feature-card">
        <span class="feature-card__icon">🏠</span>
        <h3>Zonas techadas</h3>
        <p>Refugio cómodo ante cualquier condición climática.</p>
      </div>
      <div class="feature-card">
        <span class="feature-card__icon">🐈</span>
        <h3>Gateras ambientadas</h3>
        <p>Casitas, troncos y plantas para que los gatos se sientan en casa.</p>
      </div>
    </div>

    <!-- Locations -->
    <div class="locations reveal-group" style="margin-top:3rem">
      <div class="location-card">
        <div class="location-card__top">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--green)"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <h3>Predio en Pilar</h3>
        </div>
        <p>Nuestro predio principal donde las mascotas disfrutan de todo el espacio verde.</p>
        <a href="https://maps.google.com/?q=Las+Lunas+Pilar+Buenos+Aires" target="_blank" rel="noopener" class="btn btn-outline" style="margin-top:1rem; width:fit-content">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
          Cómo llegar
        </a>
      </div>
      <div class="location-card">
        <div class="location-card__top">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--green)"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <h3>Oficina de atención al cliente</h3>
        </div>
        <p>Zona norte del GBA para coordinar traslados y consultas personalizadas.</p>
        <a href="https://maps.google.com/?q=Las+Lunas+oficina+Buenos+Aires" target="_blank" rel="noopener" class="btn btn-outline" style="margin-top:1rem; width:fit-content">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
          Cómo llegar
        </a>
      </div>
    </div>

    <!-- CTA more photos -->
    <div class="text-center reveal" style="margin-top:3rem">
      <a href="/galeria" class="btn btn-primary" style="font-size:1rem; padding:0.9rem 2rem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        ¡Más fotos acá!
      </a>
    </div>
  </div>
</section>

<style>
.instalaciones { background: var(--gray-light); }

.instalaciones__header { text-align: center; margin-bottom: 3rem; }
.instalaciones__intro {
  font-size: 1.1rem;
  color: var(--gray-mid);
  max-width: 560px;
  margin: 1rem auto 0;
}

/* Mosaic */
.mosaic {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 3rem;
}

@media (min-width: 768px) {
  .mosaic { grid-template-columns: 1fr 1fr; grid-template-rows: 400px; }
}

.mosaic__big {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
  min-height: 280px;
}
.mosaic__big img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.mosaic__big:hover img { transform: scale(1.04); }

.mosaic__label {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  background: rgba(255,255,255,0.92);
  color: var(--green-dark);
  font-size: 0.85rem;
  font-weight: 600;
  padding: 0.4rem 0.9rem;
  border-radius: 50px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.mosaic__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.mosaic__grid img {
  border-radius: var(--radius);
  object-fit: cover;
  width: 100%;
  height: 190px;
  transition: transform 0.4s;
}
.mosaic__grid img:hover { transform: scale(1.03); }

/* Feature cards */
.features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}

.feature-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 1.75rem 1.5rem;
  border: 1px solid rgba(45,106,79,0.1);
  transition: transform 0.25s, box-shadow 0.25s;
}
.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(45,106,79,0.12);
}
.feature-card__icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
.feature-card h3 { font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--green-dark); }
.feature-card p { font-size: 0.9rem; color: var(--gray-mid); line-height: 1.55; }

/* Locations */
.locations {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 768px) { .locations { grid-template-columns: 1fr 1fr; } }

.location-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2rem;
  border: 1px solid rgba(45,106,79,0.1);
}
.location-card__top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 0.75rem;
}
.location-card h3 { font-family: var(--font-body); font-size: 1.1rem; color: var(--green-dark); }
.location-card p { font-size: 0.95rem; color: var(--gray-mid); }

.text-center { text-align: center; }
</style>
