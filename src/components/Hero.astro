<section id="inicio" class="hero">
  <!-- Video background -->
  <div class="hero__media">
    <video
      class="hero__video"
      src="https://www.las-lunas.com.ar/video/institucional.mp4"
      autoplay
      muted
      loop
      playsinline
      poster="/images/hero-poster.jpg"></video>
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__text">
      <p class="section-tag reveal" style="color:var(--green-pale)">
        Hospedaje profesional · Pilar, Buenos Aires
      </p>
      <h1 class="reveal" style="transition-delay:0.1s">
        ¡Bienvenidos a<br />
        <span class="text-accent">Las Lunas!</span>
      </h1>
      <p class="hero__sub reveal" style="transition-delay:0.2s">
        Hospedaje profesional y seguro para tu mascota.<br />
        Acá vienen a correr, jugar, descansar y recibir cariño:<br />
        <em>felicidad para ellos y tranquilidad para vos.</em>
      </p>
      <div class="hero__ctas reveal" style="transition-delay:0.3s">
        <a
          href="https://api.whatsapp.com/send?phone=5491150968576&text=Hola!%20Quiero%20recibir%20m%C3%A1s%20informaci%C3%B3n%20de%20hospedaje%20para%20mi%20mascota%20en%20Las%20Lunas.%20"
          target="_blank"
          class="btn btn-primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path></svg
          >
          Consultar ahora
        </a>
        <a href="#conocenos" class="btn btn-white">
          Conocer más
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg
          >
        </a>
      </div>
    </div>

    <!-- Floating stats -->
    <div class="hero__stats reveal" style="transition-delay:0.4s">
      <div class="stat">
        <span class="stat__num">1985</span>
        <span class="stat__label">Desde</span>
      </div>
      <div class="stat">
        <span class="stat__num">6000m²</span>
        <span class="stat__label">Área verde</span>
      </div>
      <div class="stat">
        <span class="stat__num">100%</span>
        <span class="stat__label">Personalizado</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--pre-header-h) + var(--header-h));
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0d1b15 0%, #1b4332 50%, #0d1b15 100%);
    /* background: linear-gradient(
    135deg,
    rgba(13,13,13,0.72) 0%,
    rgba(27,67,50,0.55) 60%,
    rgba(13,13,13,0.45) 100%
  ); */
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-block: 5rem;
  }

  @media (min-width: 900px) {
    .hero__content {
      grid-template-columns: 1fr auto;
      align-items: flex-end;
      gap: 4rem;
    }
  }

  .hero__text h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--white);
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .text-accent {
    color: var(--accent);
  }

  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 560px;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Stats */
  .hero__stats {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(8px);
    overflow: hidden;
    min-width: 160px;
    align-self: flex-end;
  }

  @media (max-width: 899px) {
    .hero__stats {
      flex-direction: row;
      align-self: auto;
    }
  }

  .stat {
    padding: 1.25rem 1.5rem;
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    transition: background 0.25s;
  }
  .stat:last-child {
    border-bottom: none;
  }
  .stat:hover {
    background: rgba(45, 106, 79, 0.4);
  }

  @media (max-width: 899px) {
    .stat {
      flex: 1;
      border-bottom: none;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
    }
    .stat:last-child {
      border-right: none;
    }
  }

  .stat__num {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat__label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .hero__scroll span {
    display: block;
    width: 2px;
    height: 8px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 2px;
    animation: scrollDot 1.5s infinite;
  }
  .hero__scroll span:nth-child(2) {
    animation-delay: 0.2s;
  }
  .hero__scroll span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes scrollDot {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.4);
    }
  }
</style>
