<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    background: #1b4332;
    padding-top: calc(var(--pre-header-h) + var(--header-h));
    overflow: hidden;
  }

  /* ── VIDEO IZQUIERDA ── */
  .hero__media {
    position: relative;
    width: 55%;
    flex-shrink: 0;
    clip-path: polygon(0 0, 100% 0, 86% 100%, 0 100%);
    z-index: 1;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero__media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(8, 28, 21, 0.15);
  }

  /* ── CONTENIDO DERECHA ── */
  .hero__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 5rem 5rem 6rem;
    position: relative;
    z-index: 2;
  }

  /* ── PATITAS ── */
  .hero__deco {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  /* Desktop: mostrar la versión grande, ocultar la de móvil */
  .hero__deco--mobile {
    display: none;
  }
  .hero__deco--desktop {
    display: block;
  }

  .hero__badge,
  .hero__eyebrow,
  .hero__content h1,
  .hero__title-line,
  .hero__sub,
  .hero__ctas {
    position: relative;
    z-index: 1;
  }

  /* ── BADGE ── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50px;
    color: #95d5b2;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.4rem;
    width: fit-content;
  }

  /* ── EYEBROW ── */
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #52b788;
    margin-bottom: 0.5rem;
  }
  .hero__eyebrow span {
    display: block;
    width: 24px;
    height: 2px;
    background: #52b788;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── TÍTULO ── */
  .hero__content h1 {
    font-size: clamp(4.5rem, 9vw, 8.5rem);
    color: #ffffff;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    font-weight: 900;
  }

  .text-accent {
    color: #52b788;
  }

  .hero__title-line {
    width: 72px;
    height: 4px;
    background: #52b788;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  /* ── SUBTÍTULO ── */
  .hero__sub {
    font-size: clamp(0.9rem, 1.4vw, 1.15rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    margin-bottom: 3rem;
    max-width: 480px;
  }
  .hero__sub em {
    font-style: normal;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ── BOTONES ── */
  .hero__ctas {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 1rem 2.25rem;
    background: #52b788;
    color: #1b4332;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(82, 183, 136, 0.3);
  }
  .btn-primary svg {
    fill: #1b4332;
    flex-shrink: 0;
  }
  .btn-primary:hover {
    background: #74c69d;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(82, 183, 136, 0.4);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border: 1.5px solid rgba(255, 255, 255, 0.22);
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s;
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  /* ── RESPONSIVE TABLET 900–1200 ── */
  @media (min-width: 900px) and (max-width: 1200px) {
    .hero__content {
      padding: 4rem 2rem 4rem 3rem;
    }
    .hero__media {
      width: 50%;
    }
  }

  /* ── RESPONSIVE TABLET PEQUEÑA 900–1050 ── */
  @media (min-width: 900px) and (max-width: 1050px) {
    .hero__content {
      padding: 3rem 1.5rem 3rem 2.5rem;
    }
    .hero__media {
      width: 46%;
    }
  }

  /* ── RESPONSIVE MÓVIL ── */
  @media (max-width: 899px) {
    .hero {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__media {
      width: 100%;
      height: 45vh;
      clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%);
    }

    .hero__content {
      padding: 3rem 1.75rem 4rem;
      align-items: center;
      text-align: center;
    }

    /* En móvil: ocultar desktop, mostrar móvil */
    .hero__deco--desktop {
      display: none;
    }
    .hero__deco--mobile {
      display: block;
    }

    .hero__content h1 {
      /* En móvil el título no compite con nada, puede ser más grande */
      font-size: clamp(3rem, 12vw, 5rem);
    }

    .hero__badge {
      margin: 0 auto 1.4rem;
    }
    .hero__eyebrow {
      justify-content: center;
    }
    .hero__eyebrow span {
      display: none;
    }
    .hero__title-line {
      margin: 0 auto 1.75rem;
    }
    .hero__sub {
      margin: 0 auto 2rem;
    }
    .hero__ctas {
      justify-content: center;
    }
  }
</style>
