---
import videoHero from "../assets/video servicios.mp4";
---

<section id="inicio" class="hero">
  <!-- VIDEO LADO IZQUIERDO -->
  <div class="hero__media">
    <video class="hero__video" src={videoHero} autoplay muted loop playsinline
    ></video>
    <div class="hero__media-overlay"></div>
  </div>

  <!-- CONTENIDO LADO DERECHO -->
  <div class="hero__content">
    <!-- Decoración SVG: arco curvo que abraza el título -->
    <svg
      class="hero__deco"
      viewBox="0 0 600 700"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Arco principal punteado -->
      <path
        d="M 460 80 Q 620 160 620 350 Q 620 540 460 620"
        fill="none"
        stroke="#fffff0"
        stroke-width="2"
        stroke-dasharray="8 7"
        stroke-linecap="round"
        opacity="1"></path>
      <!-- Arco interior más sutil -->
      <path
        d="M 440 110 Q 575 185 575 350 Q 575 515 440 590"
        fill="none"
        stroke="#fffff0"
        stroke-width="1"
        stroke-linecap="round"
        opacity="1"></path>
      <!-- Puntos en los extremos del arco principal -->
      <circle cx="460" cy="80" r="4" fill="#fffff0" opacity="1"></circle>
      <circle cx="460" cy="620" r="4" fill="#fffff0" opacity="1"></circle>
      <!-- Rayitas cortas decorativas al lado del arco -->
      <line
        x1="635"
        y1="280"
        x2="665"
        y2="280"
        stroke="#fffff0"
        stroke-width="1.5"
        stroke-linecap="round"
        opacity="1"></line>
      <line
        x1="640"
        y1="300"
        x2="660"
        y2="300"
        stroke="#fffff0"
        stroke-width="1"
        stroke-linecap="round"
        opacity="1"></line>
      <line
        x1="635"
        y1="400"
        x2="665"
        y2="400"
        stroke="#fffff0"
        stroke-width="1.5"
        stroke-linecap="round"
        opacity="1"></line>
      <line
        x1="640"
        y1="420"
        x2="660"
        y2="420"
        stroke="#fffff0"
        stroke-width="1"
        stroke-linecap="round"
        opacity="1"></line>
    </svg>

    <div class="hero__badge reveal">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
        ></path>
      </svg>
      Pilar, Buenos Aires
    </div>

    <div class="hero__eyebrow reveal" style="transition-delay: 0.05s;">
      <span></span>Bienvenidos a
    </div>

    <h1 class="reveal" style="transition-delay: 0.08s;">
      ¡Las<br />
      <span class="text-accent">Lunas!</span>
    </h1>

    <div class="hero__title-line reveal" style="transition-delay: 0.13s;"></div>

    <p class="hero__sub reveal" style="transition-delay: 0.18s;">
      Hospedaje profesional y seguro para tu mascota.<br />
      Acá vienen a correr, jugar, descansar y recibir cariño:<br />
      <em>Felicidad para ellos y tranquilidad para vos.</em>
    </p>

    <div class="hero__ctas reveal" style="transition-delay: 0.25s;">
      <a href="#conocenos" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"
          ></path>
        </svg>
        Conocer más
      </a>
      <!-- <a href="#servicios" class="btn-ghost"> Ver servicios → </a> -->
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    background: #1b4332;
    padding-top: calc(var(--pre-header-h) + var(--header-h));
    overflow: hidden;
  }

  /* ── VIDEO IZQUIERDA ── */
  .hero__media {
    position: relative;
    width: 55%;
    flex-shrink: 0;
    /* Diagonal que sale hacia la derecha */
    clip-path: polygon(0 0, 100% 0, 86% 100%, 0 100%);
    z-index: 1;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Overlay sutil solo para oscurecer levemente el video */
  .hero__media-overlay {
    position: absolute;
    inset: 0;
    background: rgba(8, 28, 21, 0.15);
  }

  /* ── CONTENIDO DERECHA ── */
  .hero__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 5rem 5rem 6rem;
    position: relative;
    z-index: 2;
  }

  /* ── ARCO DECORATIVO ── */
  .hero__deco {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
    left: -350px;
  }

  .hero__badge,
  .hero__eyebrow,
  .hero__content h1,
  .hero__title-line,
  .hero__sub,
  .hero__ctas {
    position: relative;
    z-index: 1;
  }

  /* ── BADGE ── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50px;
    color: #95d5b2;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.4rem;
    width: fit-content;
  }

  /* ── EYEBROW ── */
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #52b788;
    margin-bottom: 0.5rem;
  }
  .hero__eyebrow span {
    display: block;
    width: 24px;
    height: 2px;
    background: #52b788;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── TÍTULO ── */
  .hero__content h1 {
    font-size: clamp(4.5rem, 9vw, 8.5rem);
    color: #ffffff;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    font-weight: 900;
  }

  .text-accent {
    color: #52b788;
  }

  /* Línea verde bajo el título */
  .hero__title-line {
    width: 72px;
    height: 4px;
    background: #52b788;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  /* ── SUBTÍTULO ── */
  .hero__sub {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    margin-bottom: 3rem;
    max-width: 520px;
  }
  .hero__sub em {
    font-style: normal;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
  }

  /* ── BOTONES ── */
  .hero__ctas {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 1rem 2.25rem;
    background: #52b788;
    color: #1b4332;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(82, 183, 136, 0.3);
  }
  .btn-primary svg {
    fill: #1b4332;
    flex-shrink: 0;
  }
  .btn-primary:hover {
    background: #74c69d;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(82, 183, 136, 0.4);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border: 1.5px solid rgba(255, 255, 255, 0.22);
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s;
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 899px) {
    .hero {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__media {
      width: 100%;
      height: 45vh;
      clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%);
    }

    .hero__content {
      padding: 3rem 1.75rem 4rem;
      align-items: center;
      text-align: center;
    }

    .hero__badge {
      margin: 0 auto 1.4rem;
    }

    .hero__title-line {
      margin: 0 auto 1.75rem;
    }

    .hero__sub {
      margin: 0 auto 2rem;
    }

    .hero__ctas {
      justify-content: center;
    }
  }

  @media (min-width: 900px) and (max-width: 1200px) {
    .hero__content {
      padding: 4rem 3rem 4rem 4rem;
    }
  }
</style>
